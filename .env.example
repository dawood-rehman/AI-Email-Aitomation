# ===========================================
# AI Email Marketing Tool - Environment Config
# Copy this file to .env and fill in your values
# ===========================================

# MongoDB Database
MONGODB_URI=mongodb://localhost:27017/email-marketing-tool

# JWT Authentication (use a strong random string in production)
JWT_SECRET=

# OpenRouter API (required for AI email generation)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# SMTP Email Configuration (default fallback; users can override in settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=AI Email Assistant
FROM_EMAIL=
SMTP_SECURE=false

# Application Settings
COMPANY_NAME=Our Company
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
